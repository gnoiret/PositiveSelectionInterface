<!doctype html>
<html lang="en">
  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <title>Homepage</title>

    <!-- Bootstrap core CSS -->
    <link href="//maxcdn.bootstrapcdn.com/bootstrap/3.2.0/css/bootstrap.min.css"rel="stylesheet">

    <style>

      .bd-placeholder-img {
        font-size: 1.125rem;
        text-anchor: middle;
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      @media (min-width: 768px) {
        .bd-placeholder-img-lg {
          font-size: 3.5rem;
        }
      }

      header {
        padding-bottom: 3rem;
      }

      body {
        padding-top: 0rem;
        padding-bottom: 3rem;
        color: #5a5a5a;
      }

      footer {
        padding-top: 1rem;
        padding-bottom: 3rem;
      }


      h1{
          padding-bottom: 30px;
      }

      h2{
        font-weight: 300;
        padding-bottom: 30px;
      }

      h5{
          color: #708090;
      }

    /* Ajout de l'effet souligné */

      .etape{
    text-decoration:none;
    padding: 0 10px;
    padding-bottom: 10px;
    text-align: center;
    }

    .etape:after {
    	content: '';
    	display: block;
    	margin: auto;
    	height: 1px;
    	width: 0;
    	background: transparent;
    	transition: width .5s ease, background-color .5s ease;
    }

      .etape:hover:after {
        width: 90%;
      	background: lightgrey;
      }

      .Option{
    text-decoration:none;
    padding: 5px 0px;
    padding-bottom: 1px;
    text-align: center;
    }

    .Option:after {
      content: '';
      display: block;
      margin: auto;
      height: 1px;
      width: 0;
      background: transparent;
      transition: width .5s ease, background-color .5s ease;
    }

      .Option:hover:after {
        width: 90%;
        background: lightgrey;
      }

      /* Fin de l'ajout de l'effet souligné */

      /* MARKETING CONTENT
      -------------------------------------------------- */

      /* Center align the text within the three columns below the carousel */
      .marketing .col-lg-4 {
        margin-bottom: 1.5rem;
        text-align: center;
      }

      #tutoriel {
        font-weight: 400;
      }

      .marketing .col-lg-4 p {
        margin-right: .75rem;
        margin-left: .75rem;
      }


      /* Featurettes
      ------------------------- */

      .featurette-divider {
        margin: 5rem 0; /* Space out the Bootstrap <hr> more */
      }

      /* Thin out the marketing headings */
      .featurette-heading {
        font-weight: 300;
        line-height: 1;
        letter-spacing: -.05rem;
      }
      .featurette {
        padding-left: 5rem;
      }


      /* RESPONSIVE CSS
      -------------------------------------------------- */

      @media (min-width: 40em) {
        /* Bump up size of carousel content */

        .featurette-heading {
          font-size: 40px;
        }
      }

      @media (min-width: 62em) {
        .featurette-heading {
          margin-top: 1rem;
        }
      }

      p {
        margin-top: 0;
        margin-bottom: 0;
      }

      img {
        max-width: 1250px;
        max-height: 1000px;
        padding-bottom: 30px;
      }

      #options{
        padding-bottom: 10px;
      }
      .OptionsRow2{
        padding-left: 200px;
      }

    </style>


    <!-- Custom styles for this template -->

  </head>
  <body>

    <% include ../partials/header %>

    <header>

      <div class="container-fluid">
        <h1 class="text-center">Interface web pour la sélection positive</h1>
        <h2 class="text-center"><span class="text-muted">Comment visualiser vos données ?</span></h2>
        </div>
      </div>

    </header>


  <main>

    <!-- Partie 1 -->
    <div class="container marketing">

      <!-- Three columns of text below the carousel -->
      <div class="row">
        <div class="col-lg-4">
          <svg class="bd-placeholder-img rounded-circle" width="120" height="120" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder: 140x140" preserveAspectRatio="xMidYMid slice" focusable="false"><title>Placeholder</title>
            <rect width="100%" height="100%" fill="#708090" rx="15" ry="15"/>
            <text x="50%" y="50%" fill="white" dy=".3em" font-size="8rem">1</text>
          </svg>
          <h2 class="etape" id="tutoriel">Étape 1</h2>
          <p class="text-center">Depuis votre terminal, clonez le git via la commande : </p>
          <p class="text-center">git clone https://github.com/gnoiret/Projet_S1.git <p/>
          <p class="text-center">Puis, installez les modules nécéessaires. <p/>
        </div>

        <div class="col-lg-4">
          <svg class="bd-placeholder-img rounded-circle" width="120" height="120" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder: 140x140" preserveAspectRatio="xMidYMid slice" focusable="false"><title>Placeholder</title>
            <rect width="100%" height="100%" fill="#708090" rx="15" ry="15"/>
            <text x="50%" y="50%" fill="white" dy=".3em" font-size="8rem">2</text>
          </svg>
          <h2 class="etape" id="tutoriel">Étape 2</h2>
          <p class="text-center">Générez un fichier xml via la commande : python3 genere_xml.py file_arbre file_alignement file_résultats</p>
          <p class="text-center">Puis exécutez la commande : cp file_arbre.xml input_tree.xml <p/>
        </div>

        <div class="col-lg-4">
          <svg class="bd-placeholder-img rounded-circle" width="120" height="120" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder: 140x140" preserveAspectRatio="xMidYMid slice" focusable="false"><title>Placeholder</title>
            <rect width="100%" height="100%" fill="#708090" rx="15" ry="15"/>
            <text x="50%" y="50%" fill="white" dy=".3em" font-size="8rem">3</text>
          </svg>
          <h2 class="etape" id="tutoriel">Étape 3</h2>
          <p class="text-center">Lancez le serveur via la commande : npm start</p>
          <p class="text-center">Vos résultats sont maintenant accessibles en cliquant sur Display !</p>
        </div>
      </div>
    </div>

    <!-- Partie 2 -->

    <hr class="featurette-divider">

      <!-- Exemple d'affichage -->

      <div class="container-fluid text-center">
        <h2 class="featurette-heading text-center">Un exemple d'affichage ... </h2>
        <img src="https://scontent-cdg2-1.xx.fbcdn.net/v/t1.15752-9/256353432_1273879479752352_289156893457297206_n.png?_nc_cat=108&ccb=1-5&_nc_sid=ae9488&_nc_ohc=64jQ0i1P--AAX8wATiE&_nc_ht=scontent-cdg2-1.xx&oh=1aa622e642432e70d99064b4665c1541&oe=61B55AA4" alt="exemple d'affichage" width="1050" height="500"/>
      </div>

      <!-- Description des options d'affichage -->

      <div class="container-fluid">
        <h2 class="text-center"><span class="text-muted">... et ses différentes options :</span></h2>

        <div class="col-lg-3">
          <h5 class="Option">On click</h5>
          <p class="text-center">Inversion de branches <br/> Sélection de noeuds à afficher</p>
        </div>

        <div class="col-lg-3">
          <h5 class="Option">Expand/Compact tree</h5>
          <p class="text-center">Augmentation/Diminution <br/> de l'espace inter-branches</p>
        </div>

          <div class="col-lg-3" id="options">
            <h5 class="Option text-center">AlignmentNature</h5>
            <p class="text-center">Affichage de séquences <br/> nucléiques ou protéiques</p>
          </div>

          <div class="col-lg-3" id="options">
            <h5 class="Option">WidthSize +/- </h5>
            <p class="text-center">Augmentation/Diminution <br/> de la largeur de l'arbre</p>
          </div>

          <div class="OptionsRow2">
            <div class="col-lg-3" id="options">
              <h5 class="Option">HeightSize +/- </h5>
              <p class="text-center">Augmentation/Diminution <br/> de la longueur de l'arbre et de l'alignement</p>
            </div>

            <div class="col-lg-4" id="options">
              <h5 class="Option">ExportSVG</h5>
              <p class="text-center">Exportation des figures <br/> au format svg</p>
            </div>

            <div class="col-lg-3" id="options">
              <h5 class="Option">Upper / Lower threshold</h5>
              <p class="text-center">Choix du seuil supérieur/inférieur<br/>de valeurs de sélection positive </p>
            </div>
            </div>
        </div>
          <hr class="featurette-divider">


    <!-- FOOTER -->

    <footer class="container">
      <p class="float-end"><a href="#">Back to top</a></p>
      <p>&copy; 2017–2021 Company, Inc. </p>
    </footer>
  </main>

  <!-- FIN FOOTER -->


    <script src="../assets/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>
