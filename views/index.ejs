<!doctype html>
<html lang="en">
  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <!-- <title>Homepage</title> -->
    <title><%= title %></title>

    <!-- Bootstrap core CSS -->
    <link href="//maxcdn.bootstrapcdn.com/bootstrap/3.2.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.css" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>

      .bd-placeholder-img {
        font-size: 1.125rem;
        text-anchor: middle;
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      @media (min-width: 768px) {
        .bd-placeholder-img-lg {
          font-size: 3.5rem;
        }
      }


      body {
        padding-top: 0rem;
        padding-bottom: 3rem;
        color: #5a5a5a;
      }

      footer {
        padding-top: 1rem;
        padding-bottom: 3rem;
      }


      h1{
          padding-bottom: 0px;
      }

      h2{
        font-weight: 300;
        padding-bottom: 30px;
      }

      h5{
          color: #708090;
      }

      /* Ajout de l'effet souligné */

      .Option{
        text-decoration:none;
        padding: 5px 0px;
        padding-bottom: 1px;
        text-align: center;
      }

      .Option:after {
        content: '';
        display: block;
        margin: auto;
        height: 1px;
        width: 0;
        background: transparent;
        transition: width .5s ease, background-color .5s ease;
      }

      .Option:hover:after {
        width: 90%;
        background: lightgrey;
      }

      /* Fin de l'ajout de l'effet souligné */



      /* Featurettes
      ------------------------- */

      .featurette-divider {
        padding-bottom: 2rem;
      }

      /* Thin out the marketing headings */
      .featurette-heading {
        font-weight: 300;
        line-height: 1;
        letter-spacing: -.05rem;
      }
      .featurette {
        padding-left: 5rem;
      }


      /* RESPONSIVE CSS
      -------------------------------------------------- */

      @media (min-width: 40em) {
        /* Bump up size of carousel content */

        .featurette-heading {
          font-size: 40px;
        }
      }

      @media (min-width: 62em) {
        .featurette-heading {
          margin-top: 10rem;
        }
      }

      p {
        margin-top: 0;
        margin-bottom: 0;
      }

      #options{
        padding-bottom: 10px;
      }

      /* Formulaire */

      .form{
        margin: 0 auto;
        margin-top: 40px;
        margin-bottom: 40px;
        width: 250px; 
      }

      label {
        text-align: center;
        padding-top: 20px;
        display: inline-block;
        cursor: pointer;
      }

      .inputfile {
        font-size: 1em;
        font-weight: 700;
        border-radius : 10px;
        display: inline-block;
        cursor: pointer;
      }

      #submit{
        text-align: center;
        margin-top: 15px;
        margin-left:10%;
        width: 200px;
        background-color: #ffffff;
        border-radius: 5px;
      }

      #submit:hover {
          background-color: #dddddd;
      }
    </style>

    <!-- Custom styles for this template -->

  </head>
  <body>
    <header>
      <% include ../partials/header %>
      <div class="container-fluid">
        <h1 class="text-center">Web interface for positive selection</h1>
        </div>
      </div>
    </header>

    <main>
      <div>
        <h3>Tree</h3>
        <p id="tree-file-content"></p>
      </div>
      <div>
        <div>
          <h3>Alignment</h3>
          <p id="alignment-file-content"></p>
        </div>
      </div>
      <div>
        <div>
          <h3>Results</h3>
          <p id="results-file-content"></p>
        </div>
      </div>
      <div class="form">
        <form method="post" action="/upload_files" enctype="multipart/form-data">
          <div class="form-group">
            <label class="btn btn-default btn-sm center-block btn-file">
              <i class="fa fa-upload fa-2x" aria-hidden="true"><br>Tree file</i>
              <input id="tree-file-input" type="file" name="file_t" class="inputfile" style="display: none;" required />
              <p class="filename"></p>
              <div id="tree-file-check-mark"></div>
            </label>
          <!-- </div> -->
          <!-- <div class="form-group"> -->
            <label class="btn btn-default btn-sm center-block btn-file">
              <i class="fa fa-upload fa-2x" aria-hidden="true"><br>Alignment file</i>
              <input id="alignment-file-input" type="file" name="file_a" class="inputfile" style="display: none;" required />
              <p class="filename"></p>
              <div id="alignment-file-check-mark"></div>
            </label>
          <!-- </div> -->
          <!-- <div class="form-group"> -->
            <label class="btn btn-default btn-sm center-block btn-file">
              <i class="fa fa-upload fa-2x" aria-hidden="true"><br>Results file</i>
              <input id="results-file-input" type="file" name="file_r" clas="inputfile" style="display: none;" required />
              <p class="filename"></p>
              <div id="results-file-check-mark"></div>
            </label>
          </div>
          
          <div class="form-group">
            <label for="statcol">Statistics column</label>
            <input id="statcol" class="form-control" type="number" name="statcol" value="1" min="0" step="1" required />
          <!-- </div> -->
          <!-- <div class="form-group"> -->
            <label for="nostat">Missing statistics value</label>
            <input id="nostat" class="form-control" type="number" name="nostat" value="-1" step="1" required />
          </div>
          
          <div class="form-group">
            <input id="is-sitebranch" class="col-xs-3 pull-left" type="checkbox" name="is-sitebranch" />
            <label class="col-xs-9" for="is-sitebranch">Statistics column</label>
          </div>

          <button type="submit" id="submit">Display</button>
        </form>
      </div>

      <!-- Exemple d'affichage -->

      <div class="container-fluid text-center">
        <h2 class="text-center"><span class="text-muted">An example of display...</span></h2>
        <!-- <img src="public/ExempleAffichage.png" alt="exemple d'affichage" width="1050" height="500"/> -->
        <!-- <img src="media/ExempleAffichage.png" alt="exemple d'affichage" /> -->
      </div>

      <!-- Description des options d'affichage -->

      <div class="container-fluid text-center">
        <h2 class="text-center"><span class="text-muted">...and its various options</span></h2>

        <div class="col-lg-3">
          <h5 class="Option">On click</h5>
          <p class="text-center">Reverse branches <br/> Select nodes to display</p>
        </div>

        <div class="col-lg-3">
          <h5 class="Option">Expand/Compact tree</h5>
          <p class="text-center">Increase/Decrease <br/> spaces between branches</p>
        </div>

        <div class="col-lg-3" id="options">
          <h5 class="Option text-center">AlignmentNature</h5>
          <p class="text-center">Display of nucleotid <br/> or protein sequences</p>
        </div>

        <div class="col-lg-3" id="options">
          <h5 class="Option">WidthSize +/- </h5>
          <p class="text-center">Increase/Decrease <br/> the tree's width</p>
        </div>

        <div class="col-lg-3 " id="options">
          <h5 class="Option">HeightSize +/- </h5>
          <p class="text-center">Increase/Decrease <br/> the tree's height</p>
        </div>

        <div class="col-lg-3" id="options">
          <h5 class="Option">ExportSVG</h5>
          <p class="text-center">Results export <br/> in svg format</p>
        </div>

        <div class="col-lg-3" id="options">
          <h5 class="Option">Upper / Lower threshold</h5>
          <p class="text-center">Choice of upper/lower threshold<br/>of positive selection values</p>
        </div>
      </div>
      
      <hr class="featurette-divider">

      <footer class="container text-center">
        <p class="float-end"><a href="#">Back to top</a></p>
        <!-- <p>&copy; Master Bioinformatique, Université Lyon 1. </p> -->
      </footer>
    </main>

  </body>
  <script type="text/javascript">
  $(document).ready(function() {
    $('[id$="-file-input"]').each(function(i, elt) {
      // console.log(i, elt.id);
      if ($('#'+elt.id).val() != '') {
        // console.log(elt.id+' has file '+$('#'+elt.id)[0].files[0].name);
        $("#"+elt.id+" + .filename").html('✅ '+$('#'+elt.id)[0].files[0].name);
        
        // var treeFile = document.getElementById('tree-file-input').files[0];
        // // var alignmentFile = document.getElementById('alignment-file-input').files[0];
        // // var resultsFile = document.getElementById('results-file-input').files[0];
        // var treeContent = document.getElementById('tree-file-content');
        // // var alignmentContent = document.getElementById('alignment-file-content');
        // // var resultsContent = document.getElementById('results-file-content');
        // var treeReader = new FileReader();
        // treeReader.onload = function(event) { treeContent.innerHTML = treeReader.result; };
        // treeReader.readAsText(selectedFile);

      } else {
        // console.log(elt.id + ' is empty');
        $("#"+elt.id+" + .filename").html('❌');
      }
    });
    $('input[type="file"]').change(function(e) {
      var filename = e.target.files[0].name;
      console.log('File changed on input with id: ' + e.target.id);

      var selectedFile = document.getElementById(e.target.id).files[0];
      var content = document.getElementById(e.target.id.split('-')[0]+'-file-content');
      var reader = new FileReader();
      reader.onload = function(event) {
        var lines = this.result.split('\n');
        var treeRegex = new RegExp('^[\(][\w0-9\-_,:\(\);]+');
        var alignmentRegex = new RegExp('^>.*\n[ACGTU\-]+');
        var resultsRegex = new RegExp('[0-9]+((\t| )[\-]?[0-9]+[\.]?[0-9]+)+');
        console.log(reader.result);
        var isMatch = null;
        if (e.target.id.substring(0, 4) === 'tree') {
          isMatch = treeRegex.test(reader.result);
        } else if (e.target.id.substring(0, 4) === 'alig') {
          isMatch = alignmentRegex.test(reader.result);
        } else if (e.target.id.substring(0, 4) === 'resu') {
          isMatch = resultsRegex.test(reader.result);
        } else {
          console.log('Unrecognized ID: '+e.target.id);
        }
        console.log(isMatch);
        if (isMatch) {
          $("#"+e.target.id+" + .filename").html('✅ '+filename); 
        } else {
          $("#"+e.target.id+" + .filename").html('❌ '+filename); 
        }
        content.innerHTML = '';
        // content.innerHTML = reader.result.substring(0, 100);
        console.log(lines);
        for (var i = 0; i < Math.min(lines.length, 4); i ++) {
          content.innerHTML += lines[i].substring(0, 80)+'<br>';
          console.log(lines[i].substring(0, 80));
        }
      };
      reader.readAsText(selectedFile);
      
      // $("#"+e.target.id+" + .filename").html('✅ '+filename);      
    });
  });
  </script>
</html>
